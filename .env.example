# Chave secreta do Django. NUNCA use o valor padrão em produção.
# Gere uma nova com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# ⚠️  Se o valor contiver "$", duplique como "$$" para o Docker não interpretar como variável.
SECRET_KEY=django-insecure-troque-esta-chave-em-producao

# Modo debug. Use True apenas em desenvolvimento. Em produção, use False.
DEBUG=True

# Hosts permitidos, separados por vírgula. Exemplos:
#   Dev local:  localhost,127.0.0.1
#   Produção:   meusite.com,www.meusite.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

CORS_ALLOWED_ORIGINS=http://localhost:3000
# Em produção: CORS_ALLOWED_ORIGINS=https://www.meusite.com,https://meusite.com

# Comentar se for utilizar o SQLite padrão do Django
DB_ENGINE=django.db.backends.postgresql
DB_NAME=powerup
DB_USER=powerup_user
DB_PASSWORD=powerup_pass
DB_HOST=db
DB_PORT=5432


# ------------------------------------------------------------------------------
# E-MAIL — Resend (https://resend.com)
# Usado para envio de e-mails transacionais (recuperação de senha, etc.)
# ------------------------------------------------------------------------------
RESEND_API_KEY=re_